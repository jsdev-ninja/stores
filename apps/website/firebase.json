{
	"hosting": [
		{
			"target": "stores-landing",
			"public": "dist/client/",
			"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
			"headers": [
				{
					"source": "**/*.html",
					"headers": [
						{
							"key": "Cache-Control",
							"value": "max-age=0, must-revalidate"
						}
					]
				},
				{
					"source": "assets/**",
					"headers": [
						{
							"key": "Cache-Control",
							"value": "public, max-age=31536000, immutable"
						}
					]
				}
			]
		}
	]
}
