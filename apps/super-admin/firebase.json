{
	"hosting": [
		{
			"target": "super-admin",
			"source": ".",
			"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
			"frameworksBackend": {
				"region": "europe-west1"
			},
			"headers": [
				{
					"source": "/",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				},
				{
					"source": "/index.html",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				},
				{
					"source": "/assets/**",
					"headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
				}
			]
		}
	]
}
