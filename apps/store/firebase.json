{
	"hosting": [
		{
			"target": "balasistore",
			"source": ".",
			"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
			"frameworksBackend": {
				"region": "europe-west1"
			},
			"headers": [
				{
					"source": "/",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				},
				{
					"source": "/index.html",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				}
			]
		},
		{
			"target": "tester",
			"source": ".",
			"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
			"frameworksBackend": {
				"region": "europe-west1"
			},
			"headers": [
				{
					"source": "/",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				},
				{
					"source": "/index.html",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				}
			]
		},
		{
			"target": "pecanis",
			"source": ".",
			"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
			"frameworksBackend": {
				"region": "europe-west1"
			},
			"headers": [
				{
					"source": "/",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				},
				{
					"source": "/index.html",
					"headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
				}
			]
		}
	],
	"functions": [
		{
			"runtime": "nodejs16",
			"source": "functions",
			"codebase": "default",
			"ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"],
			"predeploy": [
				"npm --prefix \"$RESOURCE_DIR\" run lint",
				"npm --prefix \"$RESOURCE_DIR\" run build"
			]
		}
	]
}
